# ── AI provider (required) ────────────────────────────────────────────
# "claude" (default) or "openai"
AI_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Auto-apply agent (optional) ───────────────────────────────────────
# true  = agent only collects matched jobs with ready resumes;
#         you review and click Apply on the dashboard
# false = agent applies automatically as it finds jobs
COLLECT_ONLY=true
# Default run length in hours when not passed on the command line
AGENT_RUN_HOURS=3
# Minutes between search cycles
AGENT_POLL_MINUTES=20
# Stop after this many applications in one run
AGENT_MAX_APPLICATIONS=10

# ── Job board keys (optional, enables extra sources) ──────────────────
# LinkedIn and AllJobs work without keys (public search).
INDEED_PUBLISHER_ID=
GLASSDOOR_PARTNER_ID=
GLASSDOOR_API_KEY=

# ── Auto-submit (optional, off by default) ────────────────────────────
# When true, the agent tries to submit LinkedIn Easy Apply automatically.
# Warning: automating logins may violate LinkedIn's terms of service.
AUTO_APPLY=false
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
# Set to "false" to watch the browser while it applies
AUTO_APPLY_HEADLESS=true
